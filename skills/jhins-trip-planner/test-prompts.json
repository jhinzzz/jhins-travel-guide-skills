[
  {
    "id": 1,
    "scenario": "happy-path",
    "prompt": "我想五一假期（5月1日-5月3日）和女朋友去杭州玩3天，预算5000元，我们从上海出发，喜欢吃本帮菜和杭帮菜",
    "assertions": {
      "mode": "planning-only",
      "must_contain": [
        "往返高铁",
        "龙井"
      ],
      "must_cite_source_for": [
        "high-speed rail price range",
        "high-speed rail schedule window",
        "Longjing tea shop recommendation"
      ],
      "must_have_section": [
        "round-trip transport",
        "day-by-day outline",
        "budget estimate",
        "hotel direction",
        "specialty highlights"
      ],
      "must_not_contain_literal": [
        "G7501",
        "G7503",
        "¥675"
      ],
      "rule_refs": [
        "weather-and-output.md §2",
        "transportation.md §Evidence Standard",
        "dining-rules.md §1",
        "local-specialties.md §Evidence Standard"
      ],
      "notes": "五一触发国内 peak period — dining calendar check required; pre-trip recheck block optional for planning-only."
    }
  },
  {
    "id": 2,
    "scenario": "existing-content-refactor",
    "prompt": "我有一份去大阪5天的零散旅行笔记（含酒店预订截图、餐厅清单、景点收藏），帮我整理成一份完整的行程指南页面",
