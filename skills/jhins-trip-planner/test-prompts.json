  {
    "id": 3,
    "scenario": "incomplete-inputs",
    "prompt": "下个月想出去玩几天，有什么建议？",
    "assertions": {
      "mode": "scaffold / inspiration first, then planning-only",
      "must_offer_destination_inspiration": 2,
      "must_offer_destination_inspiration_max": 3,
      "intake_order_followed": [
        "dates",
        "destination",
        "purpose/theme",
        "food preferences",
        "budget",
        "transport preference"
      ],
      "must_not_contain": [
        "specific flight number",
        "specific hotel name without user destination",
        "specific fare"
      ],
      "must_ask_one_at_a_time_or_batch_up_to_three": true,
      "rule_refs": [
        "intake.md",
        "SKILL.md §Fallback Rules (Missing dates/destination)"
      ]
    }
  },
  {
